# ── Supermolt Signals — Bot Config ─────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to git.

# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Channel IDs (use -100xxxxxxxxxx format for channels, or @handle)
# Free / public preview channel
FREE_CHANNEL_ID=-1001234567890

# Paid Tier 1 — Supermolt Signals ($49/mo)
SIGNALS_CHANNEL_ID=-1009876543210

# Paid Tier 2 — Arb Scanner Pro ($79/mo)
ARB_CHANNEL_ID=-1001122334455

# Paid Tier 3 — Alpha Concierge ($299/mo) private group
CONCIERGE_CHANNEL_ID=-1005544332211

# ── Optional ────────────────────────────────────────────────────────────────
# Node environment (development | production)
NODE_ENV=development
