{
  "name": "supermolt-telegram-bot",
  "version": "0.1.0",
  "description": "Supermolt Signals — Telegram bot for EV signals, arb alerts, and subscription management",
  "type": "module",
  "main": "dist/bot.js",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "build": "tsc",
    "start": "node dist/bot.js",
    "broadcast:signal": "tsx src/scripts/broadcast-signal.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
